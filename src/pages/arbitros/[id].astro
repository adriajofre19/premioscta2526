---
import Layout from '../../layouts/Layout.astro';
import { formatGrupoLabel } from '../../lib/fcf';
import { getArbitro, getPartidosFromDb, syncPartidosToDb } from '../../lib/partidos-db';
import type { PartidoRow } from '../../lib/partidos-db';

const { id } = Astro.params;
const shouldSync = Astro.url.searchParams.get('sync') === '1';

const { arbitro, error: arbitroError } = await getArbitro(id);

let syncMessage: string | null = null;
let syncError: string | null = null;

if (shouldSync && arbitro) {
  const result = await syncPartidosToDb(arbitro.id);
  if (result.ok) {
    syncMessage = `Sincronizados ${result.total} partidos desde FCF.`;
  } else {
    syncError = result.error;
  }
}

const { partidos, error: partidosError } = arbitro
  ? await getPartidosFromDb(arbitro.id)
  : { partidos: [] as PartidoRow[], error: null };

function parseGoles(resultado: string) {
  const m = resultado.match(/(\d+)\s*-\s*(\d+)/);
  if (!m) return null;
  return { local: Number(m[1]), visitante: Number(m[2]) };
}

const totales = partidos.reduce(
  (acc, p) => {
    const goles = parseGoles(p.resultado);
    let victorias_local = acc.victorias_local;
    let victorias_visitante = acc.victorias_visitante;
    let empates = acc.empates;

    if (goles) {
      if (goles.local > goles.visitante) victorias_local++;
      else if (goles.visitante > goles.local) victorias_visitante++;
      else empates++;
    }

    return {
      amarillas_local: acc.amarillas_local + (p.amarillas_local ?? 0),
      amarillas_visitante: acc.amarillas_visitante + (p.amarillas_visitante ?? 0),
      rojas_local: acc.rojas_local + (p.rojas_local ?? 0),
      rojas_visitante: acc.rojas_visitante + (p.rojas_visitante ?? 0),
      amarillas_ct_local: acc.amarillas_ct_local + (p.amarillas_ct_local ?? 0),
      amarillas_ct_visitante: acc.amarillas_ct_visitante + (p.amarillas_ct_visitante ?? 0),
      rojas_ct_local: acc.rojas_ct_local + (p.rojas_ct_local ?? 0),
      rojas_ct_visitante: acc.rojas_ct_visitante + (p.rojas_ct_visitante ?? 0),
      goles_local: acc.goles_local + (goles?.local ?? 0),
      goles_visitante: acc.goles_visitante + (goles?.visitante ?? 0),
      victorias_local,
      victorias_visitante,
      empates,
    };
  },
  {
    amarillas_local: 0,
    amarillas_visitante: 0,
    rojas_local: 0,
    rojas_visitante: 0,
    amarillas_ct_local: 0,
    amarillas_ct_visitante: 0,
    rojas_ct_local: 0,
    rojas_ct_visitante: 0,
    goles_local: 0,
    goles_visitante: 0,
    victorias_local: 0,
    victorias_visitante: 0,
    empates: 0,
  }
);

const n = partidos.length;
const media = (total: number) => (n > 0 ? total / n : 0);
const fmt = (valor: number) => (n > 0 ? valor.toFixed(2) : '—');

const resumen = {
  partidos: n,
  goles_totales: totales.goles_local + totales.goles_visitante,
  amarillas_jugadores: totales.amarillas_local + totales.amarillas_visitante,
  amarillas_ct: totales.amarillas_ct_local + totales.amarillas_ct_visitante,
  amarillas_totales: totales.amarillas_local + totales.amarillas_visitante + totales.amarillas_ct_local + totales.amarillas_ct_visitante,
  rojas_jugadores: totales.rojas_local + totales.rojas_visitante,
  rojas_ct: totales.rojas_ct_local + totales.rojas_ct_visitante,
  rojas_totales: totales.rojas_local + totales.rojas_visitante + totales.rojas_ct_local + totales.rojas_ct_visitante,
  victorias_local: totales.victorias_local,
  victorias_visitante: totales.victorias_visitante,
  empates: totales.empates,
};

const medias = {
  goles: fmt(media(resumen.goles_totales)),
  amarillas_local: fmt(media(totales.amarillas_local)),
  amarillas_visitante: fmt(media(totales.amarillas_visitante)),
  rojas_local: fmt(media(totales.rojas_local)),
  rojas_visitante: fmt(media(totales.rojas_visitante)),
  amarillas_ct_local: fmt(media(totales.amarillas_ct_local)),
  amarillas_ct_visitante: fmt(media(totales.amarillas_ct_visitante)),
  rojas_ct_local: fmt(media(totales.rojas_ct_local)),
  rojas_ct_visitante: fmt(media(totales.rojas_ct_visitante)),
  amarillas_totales: fmt(media(resumen.amarillas_totales)),
  rojas_totales: fmt(media(resumen.rojas_totales)),
};
---

<Layout>
  <div class="mx-auto max-w-5xl px-4 py-8">
    <a href="/" class="text-sm text-blue-600 hover:underline">← Volver a árbitros</a>

    {arbitroError && (
      <p class="mt-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-red-700">{arbitroError}</p>
    )}

    {arbitro && (
      <>
        <header class="mt-6 border-b border-gray-200 pb-6">
          <h1 class="text-2xl font-bold text-gray-900">{arbitro.nombre}</h1>
          <p class="mt-1 text-gray-600">Categoría: <span class="font-medium">{arbitro.categoria}</span></p>

          {arbitro.partidos_sync_at && (
            <p class="mt-1 text-sm text-gray-500">
              Última sincronización: {new Date(arbitro.partidos_sync_at).toLocaleString('ca-ES')}
            </p>
          )}

          <div class="mt-4 flex flex-wrap items-center gap-3">
            <form id="sync-form" method="get" action={`/arbitros/${id}`}>
              <input type="hidden" name="sync" value="1" />
              <button
                id="sync-btn"
                type="submit"
                class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 disabled:cursor-not-allowed disabled:bg-blue-300 disabled:hover:bg-blue-300"
                disabled={shouldSync}
                aria-busy={shouldSync ? 'true' : 'false'}
              >
                {shouldSync ? 'Actualizando desde FCF...' : 'Actualizar desde FCF'}
              </button>
            </form>
          </div>

          {syncMessage && <p class="mt-3 text-sm text-green-700">{syncMessage}</p>}
          {syncError && <p class="mt-3 text-sm text-red-600">{syncError}</p>}
          {partidosError && <p class="mt-3 text-sm text-red-600">{partidosError}</p>}
        </header>

        {partidos.length === 0 && !shouldSync ? (
          <p class="mt-8 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-amber-800">
            No hay partidos guardados. Pulsa «Actualizar desde FCF» para importarlos.
          </p>
        ) : (
          <>
            <!-- Resumen totales -->
            <section class="mt-8">
              <h2 class="mb-4 text-lg font-semibold text-gray-900">Resumen de la temporada</h2>
              <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
                <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
                  <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Partidos</p>
                  <p class="mt-1 text-2xl font-bold text-gray-900">{resumen.partidos}</p>
                </div>
                <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
                  <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Goles totales</p>
                  <p class="mt-1 text-2xl font-bold text-gray-900">{resumen.goles_totales}</p>
                  <p class="mt-0.5 text-xs text-gray-500">
                    {totales.goles_local} local · {totales.goles_visitante} visit.
                  </p>
                </div>
                <div class="rounded-xl border border-yellow-200 bg-yellow-50 p-4 shadow-sm">
                  <p class="text-xs font-medium uppercase tracking-wide text-yellow-800">Amarillas</p>
                  <p class="mt-1 text-2xl font-bold text-yellow-900">{resumen.amarillas_totales}</p>
                  <p class="mt-0.5 text-xs text-yellow-700">
                    {resumen.amarillas_jugadores} jug. · {resumen.amarillas_ct} CT
                  </p>
                </div>
                <div class="rounded-xl border border-red-200 bg-red-50 p-4 shadow-sm">
                  <p class="text-xs font-medium uppercase tracking-wide text-red-800">Rojas</p>
                  <p class="mt-1 text-2xl font-bold text-red-900">{resumen.rojas_totales}</p>
                  <p class="mt-0.5 text-xs text-red-700">
                    {resumen.rojas_jugadores} jug. · {resumen.rojas_ct} CT
                  </p>
                </div>
                <div class="rounded-xl border border-gray-200 bg-gray-50 p-4 shadow-sm sm:col-span-2 lg:col-span-2">
                  <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Por equipo (local / visit.)</p>
                  <div class="mt-2 grid grid-cols-2 gap-2 text-sm">
                    <div>
                      <span class="text-yellow-600">🟨</span> {totales.amarillas_local} / {totales.amarillas_visitante}
                      <span class="text-gray-400"> · </span>
                      <span class="text-red-600">🟥</span> {totales.rojas_local} / {totales.rojas_visitante}
                    </div>
                    <div class="text-gray-600">
                      CT 🟨 {totales.amarillas_ct_local} / {totales.amarillas_ct_visitante}
                      <span class="text-gray-400"> · </span>
                      🟥 {totales.rojas_ct_local} / {totales.rojas_ct_visitante}
                    </div>
                  </div>
                </div>
              </div>

              <!-- Resultados y medias -->
              <div class="mt-6 grid gap-6 lg:grid-cols-2">
                <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                  <h3 class="text-sm font-semibold text-gray-900">Resultados (victorias / empates)</h3>
                  <div class="mt-4 grid grid-cols-3 gap-3 text-center">
                    <div class="rounded-lg bg-emerald-50 px-3 py-4 ring-1 ring-emerald-200">
                      <p class="text-2xl font-bold text-emerald-800">{resumen.victorias_local}</p>
                      <p class="mt-1 text-xs font-medium text-emerald-700">Victorias locales</p>
                      {n > 0 && (
                        <p class="mt-0.5 text-xs text-emerald-600">
                          {((resumen.victorias_local / n) * 100).toFixed(0)}%
                        </p>
                      )}
                    </div>
                    <div class="rounded-lg bg-slate-50 px-3 py-4 ring-1 ring-slate-200">
                      <p class="text-2xl font-bold text-slate-800">{resumen.empates}</p>
                      <p class="mt-1 text-xs font-medium text-slate-700">Empates</p>
                      {n > 0 && (
                        <p class="mt-0.5 text-xs text-slate-600">
                          {((resumen.empates / n) * 100).toFixed(0)}%
                        </p>
                      )}
                    </div>
                    <div class="rounded-lg bg-sky-50 px-3 py-4 ring-1 ring-sky-200">
                      <p class="text-2xl font-bold text-sky-800">{resumen.victorias_visitante}</p>
                      <p class="mt-1 text-xs font-medium text-sky-700">Victorias visitantes</p>
                      {n > 0 && (
                        <p class="mt-0.5 text-xs text-sky-600">
                          {((resumen.victorias_visitante / n) * 100).toFixed(0)}%
                        </p>
                      )}
                    </div>
                  </div>
                  <p class="mt-3 text-xs text-gray-500">
                    Media de goles por partido: <span class="font-medium text-gray-700">{medias.goles}</span>
                  </p>
                </div>

                <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
                  <h3 class="text-sm font-semibold text-gray-900">Media de tarjetas por partido</h3>
                  <dl class="mt-4 space-y-2 text-sm">
                    <div class="flex justify-between border-b border-gray-100 py-2">
                      <dt class="text-gray-600">🟨 Amarillas local</dt>
                      <dd class="font-semibold text-gray-900">{medias.amarillas_local}</dd>
                    </div>
                    <div class="flex justify-between border-b border-gray-100 py-2">
                      <dt class="text-gray-600">🟨 Amarillas visitante</dt>
                      <dd class="font-semibold text-gray-900">{medias.amarillas_visitante}</dd>
                    </div>
                    <div class="flex justify-between border-b border-gray-100 py-2">
                      <dt class="text-gray-600">🟥 Rojas local</dt>
                      <dd class="font-semibold text-gray-900">{medias.rojas_local}</dd>
                    </div>
                    <div class="flex justify-between border-b border-gray-100 py-2">
                      <dt class="text-gray-600">🟥 Rojas visitante</dt>
                      <dd class="font-semibold text-gray-900">{medias.rojas_visitante}</dd>
                    </div>
                    <div class="flex justify-between border-b border-gray-100 py-2">
                      <dt class="text-gray-600">🟨 CT local</dt>
                      <dd class="font-semibold text-gray-900">{medias.amarillas_ct_local}</dd>
                    </div>
                    <div class="flex justify-between border-b border-gray-100 py-2">
                      <dt class="text-gray-600">🟨 CT visitante</dt>
                      <dd class="font-semibold text-gray-900">{medias.amarillas_ct_visitante}</dd>
                    </div>
                    <div class="flex justify-between border-b border-gray-100 py-2">
                      <dt class="text-gray-600">🟥 CT local</dt>
                      <dd class="font-semibold text-gray-900">{medias.rojas_ct_local}</dd>
                    </div>
                    <div class="flex justify-between border-b border-gray-100 py-2">
                      <dt class="text-gray-600">🟥 CT visitante</dt>
                      <dd class="font-semibold text-gray-900">{medias.rojas_ct_visitante}</dd>
                    </div>
                    <div class="flex justify-between bg-yellow-50/80 px-2 py-2 rounded-md">
                      <dt class="font-medium text-yellow-900">🟨 Total amarillas</dt>
                      <dd class="font-bold text-yellow-900">{medias.amarillas_totales}</dd>
                    </div>
                    <div class="flex justify-between bg-red-50/80 px-2 py-2 rounded-md">
                      <dt class="font-medium text-red-900">🟥 Total rojas</dt>
                      <dd class="font-bold text-red-900">{medias.rojas_totales}</dd>
                    </div>
                  </dl>
                </div>
              </div>
            </section>

            <!-- Lista de partidos -->
            <section class="mt-10">
              <h2 class="mb-4 text-lg font-semibold text-gray-900">Partidos ({partidos.length})</h2>

              <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                <div class="hidden grid-cols-[auto_1fr_auto] gap-4 border-b border-gray-200 bg-gray-50 px-4 py-2 text-xs font-medium uppercase tracking-wide text-gray-500 sm:grid">
                  <span>Jornada</span>
                  <span>Partido</span>
                  <span>Tarjetas</span>
                </div>

                <ul class="divide-y divide-gray-100">
                  {partidos.map((p) => (
                    <li class="px-4 py-4 hover:bg-gray-50/80">
                      <div class="flex flex-col gap-3 sm:grid sm:grid-cols-[auto_1fr_auto] sm:items-center sm:gap-4">
                        <div class="shrink-0">
                          <span class="inline-flex rounded-full bg-gray-100 px-2.5 py-1 text-xs font-medium text-gray-700">
                            J{p.jornada} · G{formatGrupoLabel(arbitro.categoria, p.grupo)}
                          </span>
                        </div>

                        <div class="min-w-0">
                          {p.url_acta ? (
                            <a
                              href={p.url_acta}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="group block"
                            >
                              <span class="font-semibold text-gray-900 group-hover:text-blue-600">
                                {p.local}
                              </span>
                              <span class="mx-2 inline-block rounded bg-gray-900 px-2 py-0.5 text-sm font-bold text-white">
                                {p.resultado}
                              </span>
                              <span class="font-semibold text-gray-900 group-hover:text-blue-600">
                                {p.visitante}
                              </span>
                            </a>
                          ) : (
                            <p>
                              <span class="font-semibold">{p.local}</span>
                              <span class="mx-2 rounded bg-gray-900 px-2 py-0.5 text-sm font-bold text-white">
                                {p.resultado}
                              </span>
                              <span class="font-semibold">{p.visitante}</span>
                            </p>
                          )}
                        </div>

                        <div class="flex flex-wrap gap-2 text-xs sm:justify-end">
                          <span class="rounded-md bg-yellow-50 px-2 py-1 text-yellow-800 ring-1 ring-yellow-200">
                            L 🟨 {p.amarillas_local}
                            {p.amarillas_ct_local > 0 && ` +${p.amarillas_ct_local} CT`}
                          </span>
                          <span class="rounded-md bg-red-50 px-2 py-1 text-red-800 ring-1 ring-red-200">
                            L 🟥 {p.rojas_local}
                            {p.rojas_ct_local > 0 && ` +${p.rojas_ct_local} CT`}
                          </span>
                          <span class="rounded-md bg-yellow-50 px-2 py-1 text-yellow-800 ring-1 ring-yellow-200">
                            V 🟨 {p.amarillas_visitante}
                            {p.amarillas_ct_visitante > 0 && ` +${p.amarillas_ct_visitante} CT`}
                          </span>
                          <span class="rounded-md bg-red-50 px-2 py-1 text-red-800 ring-1 ring-red-200">
                            V 🟥 {p.rojas_visitante}
                            {p.rojas_ct_visitante > 0 && ` +${p.rojas_ct_visitante} CT`}
                          </span>
                        </div>
                      </div>
                    </li>
                  ))}
                </ul>
              </div>
            </section>
          </>
        )}
      </>
    )}
  </div>
  <script>
    const syncForm = document.getElementById('sync-form');
    const syncBtn = document.getElementById('sync-btn');

    syncForm?.addEventListener('submit', () => {
      if (!(syncBtn instanceof HTMLButtonElement)) return;
      syncBtn.disabled = true;
      syncBtn.setAttribute('aria-busy', 'true');
      syncBtn.textContent = 'Actualizando desde FCF...';
    });
  </script>
</Layout>
