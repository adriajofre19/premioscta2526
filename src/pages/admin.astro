---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../db/supabase';
import {
  adminPasswordConfigured,
  clearAdminSession,
  isAdminAuthenticated,
  setAdminSession,
  verifyAdminPassword,
} from '../lib/admin-auth';
import { CATEGORIAS_ARBITRO, esCategoriaValida } from '../lib/categorias-arbitro';

let message: string | null = null;
let error: string | null = null;

const passwordOk = adminPasswordConfigured();
let authed = passwordOk && isAdminAuthenticated(Astro.cookies);

if (Astro.request.method === 'POST' && passwordOk) {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'logout') {
    clearAdminSession(Astro.cookies);
    return Astro.redirect('/admin');
  }

  if (action === 'login') {
    const password = String(formData.get('password') ?? '');
    if (verifyAdminPassword(password)) {
      setAdminSession(Astro.cookies);
      return Astro.redirect('/admin');
    }
    error = 'Contraseña incorrecta.';
  }

  if (action === 'add') {
    if (!isAdminAuthenticated(Astro.cookies)) {
      error = 'Sesión no válida. Vuelve a iniciar sesión.';
    } else {
      const nombre = String(formData.get('nombre') ?? '').trim();
      const categoria = String(formData.get('categoria') ?? '').trim();

      if (!nombre) {
        error = 'El nombre del árbitro es obligatorio.';
      } else if (!esCategoriaValida(categoria)) {
        error = 'Selecciona una categoría válida.';
      } else {
        const { error: dbError } = await supabase.from('arbitros').insert({ nombre, categoria });

        if (dbError) {
          error = `No se pudo guardar: ${dbError.message}`;
        } else {
          return Astro.redirect('/admin?ok=1');
        }
      }
    }
  }

  authed = isAdminAuthenticated(Astro.cookies);
}

if (Astro.url.searchParams.get('ok') === '1' && authed) {
  message = 'Árbitro añadido correctamente.';
}

type ArbitroRow = { id: number; nombre: string; categoria: string };

let arbitros: ArbitroRow[] = [];
let loadError: string | null = null;

if (authed) {
  const { data, error: listError } = await supabase
    .from('arbitros')
    .select('id, nombre, categoria')
    .order('nombre', { ascending: true });

  arbitros = (data ?? []) as ArbitroRow[];
  if (listError) loadError = listError.message;
}
---

<Layout>
  <div class="mx-auto max-w-5xl px-4 py-8">
    <header class="border-b border-gray-200 pb-6">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Administración</h1>
          <p class="mt-1 text-gray-600">Añadir árbitros a la base de datos</p>
        </div>
        <a
          href="/"
          class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50"
        >
          ← Inicio
        </a>
      </div>
    </header>

    {!passwordOk && (
      <p class="mt-6 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-amber-900">
        Configura <code class="rounded bg-amber-100 px-1 text-sm">ADMIN_PASSWORD</code> en tu archivo
        <code class="rounded bg-amber-100 px-1 text-sm">.env</code> para usar esta página.
      </p>
    )}

    {passwordOk && !authed && (
      <section class="mt-8 max-w-md">
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
          <h2 class="text-lg font-semibold text-gray-900">Acceso</h2>
          <p class="mt-1 text-sm text-gray-600">Introduce la contraseña de administración.</p>

          {error && (
            <p class="mt-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
              {error}
            </p>
          )}

          <form method="post" class="mt-6 space-y-4">
            <input type="hidden" name="action" value="login" />
            <div>
              <label for="admin-password" class="mb-1 block text-xs font-medium text-gray-600">
                Contraseña
              </label>
              <input
                type="password"
                id="admin-password"
                name="password"
                required
                autocomplete="current-password"
                class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20"
              />
            </div>
            <button
              type="submit"
              class="w-full rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800"
            >
              Entrar
            </button>
          </form>
        </div>
      </section>
    )}

    {passwordOk && authed && (
      <>
        {message && (
          <p class="mt-6 rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-green-800">
            {message}
          </p>
        )}
        {error && (
          <p class="mt-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-red-700">{error}</p>
        )}
        {loadError && (
          <p class="mt-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-red-700">
            Error al cargar árbitros: {loadError}
          </p>
        )}

        <section class="mt-8">
          <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <h2 class="text-lg font-semibold text-gray-900">Nuevo árbitro</h2>
              <form method="post">
                <input type="hidden" name="action" value="logout" />
                <button
                  type="submit"
                  class="text-sm font-medium text-gray-500 hover:text-gray-800"
                >
                  Cerrar sesión
                </button>
              </form>
            </div>

            <form method="post" class="mt-6 flex flex-col gap-4 sm:flex-row sm:items-end">
              <input type="hidden" name="action" value="add" />
              <div class="flex-1">
                <label for="arbitro-nombre" class="mb-1 block text-xs font-medium text-gray-600">
                  Nombre del árbitro
                </label>
                <input
                  type="text"
                  id="arbitro-nombre"
                  name="nombre"
                  required
                  placeholder="Ej. GARCÍA LÓPEZ, JUAN"
                  autocomplete="off"
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-900 placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20"
                />
              </div>
              <div class="sm:w-56">
                <label for="arbitro-categoria" class="mb-1 block text-xs font-medium text-gray-600">
                  Categoría
                </label>
                <select
                  id="arbitro-categoria"
                  name="categoria"
                  required
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-900 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20"
                >
                  <option value="" disabled selected>Seleccionar…</option>
                  {CATEGORIAS_ARBITRO.map((cat) => (
                    <option value={cat.value}>{cat.label}</option>
                  ))}
                </select>
              </div>
              <button
                type="submit"
                class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 sm:shrink-0"
              >
                Añadir árbitro
              </button>
            </form>
          </div>
        </section>

        <section class="mt-10">
          <h2 class="mb-4 text-lg font-semibold text-gray-900">
            Árbitros en la base de datos
            <span class="ml-2 text-base font-normal text-gray-500">({arbitros.length})</span>
          </h2>

          {arbitros.length === 0 ? (
            <p class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-gray-600">
              Todavía no hay árbitros.
            </p>
          ) : (
            <ul class="grid gap-3 sm:grid-cols-2">
              {arbitros.map((a) => (
                <li>
                  <a
                    href={`/arbitros/${a.id}`}
                    class="group flex items-center justify-between gap-4 rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition hover:border-blue-300 hover:shadow-md"
                  >
                    <div class="min-w-0">
                      <p class="truncate font-semibold text-gray-900 group-hover:text-blue-600">
                        {a.nombre}
                      </p>
                      <p class="mt-1 text-sm text-gray-500">Ver ficha</p>
                    </div>
                    <span class="shrink-0 rounded-full bg-gray-100 px-2.5 py-1 text-xs font-medium text-gray-700 group-hover:bg-blue-50 group-hover:text-blue-800">
                      {a.categoria}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </section>
      </>
    )}
  </div>
</Layout>
